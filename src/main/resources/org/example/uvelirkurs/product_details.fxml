<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.uvelirkurs.controllers.ProductDetailsController"
            styleClass="main-background"
            stylesheets="@styles.css">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <Button text="← Назад" 
                    onAction="#goBack"
                    styleClass="button-secondary"/>
            <Label text="Детали товара" styleClass="label-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <HBox alignment="CENTER" spacing="40" style="-fx-padding: 40;">
                
                <VBox alignment="CENTER" spacing="20" styleClass="card">
                    
                    <StackPane fx:id="imageContainer" 
                               style="-fx-pref-width: 450; -fx-pref-height: 450; -fx-background-color: #f5f5f5; -fx-background-radius: 10;"/>

                    <HBox spacing="15" alignment="CENTER">
                        <Button fx:id="prevButton" 
                                onAction="#prevImage" 
                                styleClass="button-primary"
                                style="-fx-background-radius: 50; -fx-pref-width: 45; -fx-pref-height: 45; -fx-font-size: 18px; -fx-font-family: 'Arial';">
                            <graphic>
                                <Label text="&#8592;" style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                            </graphic>
                        </Button>
                        <Label fx:id="imageCounter" 
                               text="1 / 1"
                               styleClass="label-subtitle"/>
                        <Button fx:id="nextButton" 
                                onAction="#nextImage" 
                                styleClass="button-primary"
                                style="-fx-background-radius: 50; -fx-pref-width: 45; -fx-pref-height: 45;">
                            <graphic>
                                <Label text="&#8594;" style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                            </graphic>
                        </Button>
                    </HBox>
                    
                </VBox>

                <VBox spacing="25" alignment="TOP_LEFT" maxWidth="450" styleClass="card">
                    
                    <VBox spacing="10">
                        <Label fx:id="nameLabel" 
                               text="Название товара"
                               wrapText="true"
                               styleClass="label-title"/>
                        <Label fx:id="materialLabel" 
                               text="Материал"
                               styleClass="label-subtitle"/>
                    </VBox>

                    <Region prefHeight="1" styleClass="separator-line"/>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Цена:" styleClass="label-subtitle"/>
                        <Label fx:id="priceLabel" 
                               text="0 ₽"
                               styleClass="total-price"/>
                    </HBox>

                    <VBox spacing="8">
                        <Label text="Описание" styleClass="label-subtitle" style="-fx-font-weight: bold;"/>
                        <Label fx:id="descriptionLabel" 
                               text="Описание товара"
                               wrapText="true"
                               styleClass="label-small"/>
                    </VBox>

                    <VBox spacing="8" style="-fx-background-color: #f8f9ff; -fx-background-radius: 10; -fx-padding: 15;">
                        <Label text="Характеристики" styleClass="label-subtitle" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <HBox spacing="10">
                            <Label text="Проба:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 100;"/>
                            <Label fx:id="purityLabel" text="-" style="-fx-font-size: 13px; -fx-text-fill: #333;"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Вес:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 100;"/>
                            <Label fx:id="weightLabel" text="-" style="-fx-font-size: 13px; -fx-text-fill: #333;"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Размер:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 100;"/>
                            <Label fx:id="sizeLabel" text="-" style="-fx-font-size: 13px; -fx-text-fill: #333;"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Коллекция:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 100;"/>
                            <Label fx:id="collectionLabel" text="-" style="-fx-font-size: 13px; -fx-text-fill: #333;"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="На складе:" style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-min-width: 100;"/>
                            <Label fx:id="stockLabel" text="-" style="-fx-font-size: 13px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="12" style="-fx-padding: 10 0 0 0;">
                        <Button text="🛒 Добавить в корзину" 
                                onAction="#addToCart"
                                styleClass="button-primary"
                                maxWidth="Infinity"/>
                        <Button text="Назад к каталогу" 
                                onAction="#goBack"
                                styleClass="button-secondary"
                                maxWidth="Infinity"/>
                    </VBox>

                </VBox>

            </HBox>
        </ScrollPane>
    </center>

</BorderPane>
