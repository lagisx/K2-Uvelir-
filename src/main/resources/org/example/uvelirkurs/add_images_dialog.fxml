<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<DialogPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.uvelirkurs.controllers.AddImagesDialogController"
            prefWidth="700" prefHeight="620">

    <headerText>Добавление изображений товара</headerText>

    <content>
        <VBox spacing="10" style="-fx-padding: 12;">

            <!-- Информация о товаре -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #e8f5e9; -fx-padding: 8 12; -fx-background-radius: 8;">
                <Label text="&#128230;" style="-fx-font-size: 16px;"/>
                <VBox spacing="1">
                    <Label fx:id="productNameLabel" text="Товар"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                    <Label fx:id="productIdLabel" text="ID: #0"
                           style="-fx-font-size: 11px; -fx-text-fill: #66bb6a;"/>
                </VBox>
            </HBox>

            <!-- Drag and Drop зона -->
            <VBox fx:id="dropZone" alignment="CENTER" spacing="6"
                  style="-fx-border-color: #4a5fd8; -fx-border-width: 2; -fx-border-style: dashed; -fx-border-radius: 10; -fx-background-color: #f0f4ff; -fx-background-radius: 10; -fx-padding: 14; -fx-cursor: hand;">
                <Label text="&#128444;" style="-fx-font-size: 26px;"/>
                <Label text="Перетащите изображения сюда"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5fd8;"/>
                <Label text="или" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                <Button fx:id="browseButton" text="Выбрать файлы"
                        style="-fx-background-color: #4a5fd8; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 7 20; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Label text="JPG, PNG, WEBP, GIF  |  макс. 5MB"
                       style="-fx-font-size: 10px; -fx-text-fill: #999;"/>
            </VBox>

            <!-- Превью изображений -->
            <VBox spacing="4">
                <Label text="Превью изображений:"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <ScrollPane fitToHeight="true" fitToWidth="false"
                            hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            minHeight="190" prefHeight="190" maxHeight="190"
                            style="-fx-background-color: #fafafa; -fx-border-color: #ddd; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                    <HBox fx:id="imagePreviewContainer" spacing="8" alignment="CENTER_LEFT"
                          minHeight="170"
                          style="-fx-padding: 8; -fx-background-color: #fafafa;">
                        <Label fx:id="emptyPreviewLabel" text="Изображения не выбраны"
                               style="-fx-text-fill: #aaa; -fx-font-style: italic; -fx-font-size: 12px;"/>
                    </HBox>
                </ScrollPane>
            </VBox>

            <!-- Список файлов -->
            <VBox spacing="4">
                <Label text="Выбранные файлы:"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                            minHeight="120" prefHeight="120" maxHeight="120"
                            style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1; -fx-border-radius: 8;">
                    <VBox fx:id="filesListContainer" spacing="5"
                          style="-fx-padding: 6; -fx-background-color: white;">
                        <Label fx:id="emptyFilesLabel" text="Файлы не выбраны"
                               style="-fx-text-fill: #aaa; -fx-font-style: italic; -fx-font-size: 12px;"/>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Прогресс загрузки -->
            <VBox fx:id="progressContainer" spacing="6" visible="false"
                  style="-fx-background-color: #fff3cd; -fx-padding: 10; -fx-background-radius: 8;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ProgressIndicator fx:id="uploadProgress" prefWidth="24" prefHeight="24"/>
                    <Label fx:id="progressLabel" text="Загрузка изображений..."
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #856404;"/>
                </HBox>
                <ProgressBar fx:id="uploadProgressBar" prefWidth="Infinity" progress="0"/>
            </VBox>

        </VBox>
    </content>

    <buttonTypes>
        <ButtonType text="Загрузить" buttonData="OK_DONE"/>
        <ButtonType text="Отмена" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>

</DialogPane>
