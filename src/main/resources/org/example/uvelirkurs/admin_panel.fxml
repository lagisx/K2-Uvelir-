<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.uvelirkurs.controllers.AdminPanelController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-padding: 16 24; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <VBox spacing="3">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" text="Панель Администратора"/>
                <Label style="-fx-font-size: 13px; -fx-text-fill: #888;" text="Полный контроль над системой"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="10">
                <ProgressIndicator fx:id="loadingIndicator" prefHeight="24" prefWidth="24" visible="false"/>
                <Label fx:id="statusLabel" style="-fx-font-size: 13px;" visible="false"/>
            </HBox>
            <Button text="Выйти из аккаунта"
                    onAction="#logout"
                    style="-fx-background-color: #fee2e2; -fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-padding: 24;">
            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
                     style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <Tab text="Пользователи">
                    <VBox spacing="16" style="-fx-padding: 20; -fx-background-color: white;">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <TextField fx:id="searchUserField" prefWidth="400"
                                       promptText="Поиск по имени, email, телефону..."
                                       style="-fx-font-size: 14px; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;"
                                       HBox.hgrow="ALWAYS"/>
                            <Button onAction="#searchUsers"
                                    text="Найти"
                                    style="-fx-background-color: #4a5fd8; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>

                        <Separator/>

                        <VBox VBox.vgrow="ALWAYS" spacing="8">
                            <Label text="Список пользователей"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="userIdColumn" prefWidth="60" text="ID"/>
                                    <TableColumn fx:id="usernameColumn" prefWidth="180" text="Имя пользователя"/>
                                    <TableColumn fx:id="emailColumn" prefWidth="230" text="Email"/>
                                    <TableColumn fx:id="fullnameColumn" prefWidth="200" text="Полное имя"/>
                                    <TableColumn fx:id="phoneColumn" prefWidth="150" text="Телефон"/>
                                    <TableColumn fx:id="roleColumn" prefWidth="110" text="Роль"/>
                                </columns>
                                <placeholder>
                                    <Label text="Нет пользователей" style="-fx-font-size: 15px; -fx-text-fill: #aaa;"/>
                                </placeholder>
                            </TableView>
                        </VBox>

                        <HBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-background-color: #eff6ff; -fx-padding: 10 14; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 12px; -fx-text-fill: #1d4ed8;"
                                   text="ПКМ по пользователю — просмотр, редактирование или удаление"/>
                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="Товары">
                    <VBox spacing="16" style="-fx-padding: 20; -fx-background-color: white;">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <TextField fx:id="searchProductField" prefWidth="400"
                                       promptText="Поиск по названию, материалу..."
                                       style="-fx-font-size: 14px; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;"
                                       HBox.hgrow="ALWAYS"/>
                            <Button onAction="#searchProducts"
                                    text="Найти"
                                    style="-fx-background-color: #4a5fd8; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>

                        <Separator/>

                        <VBox VBox.vgrow="ALWAYS" spacing="8">
                            <Label text="Каталог товаров"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="productIdColumn" prefWidth="60" text="ID"/>
                                    <TableColumn fx:id="productNameColumn" prefWidth="320" text="Название"/>
                                    <TableColumn fx:id="materialColumn" prefWidth="180" text="Материал"/>
                                    <TableColumn fx:id="priceColumn" prefWidth="120" text="Цена (₽)"/>
                                    <TableColumn fx:id="stockColumn" prefWidth="110" text="На складе"/>
                                </columns>
                                <placeholder>
                                    <Label text="Нет товаров" style="-fx-font-size: 15px; -fx-text-fill: #aaa;"/>
                                </placeholder>
                            </TableView>
                        </VBox>

                        <HBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-background-color: #eff6ff; -fx-padding: 10 14; -fx-background-radius: 8;">
                            <Label style="-fx-font-size: 12px; -fx-text-fill: #1d4ed8;"
                                   text="ПКМ по товару — просмотр или удаление"/>
                        </HBox>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </center>

    <stylesheets>
        <String fx:value="@admin-panel-style.css"/>
    </stylesheets>
</BorderPane>
