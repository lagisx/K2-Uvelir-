<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.uvelirkurs.controllers.ProfileController"
            styleClass="main-background"
            stylesheets="@styles.css">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <Button text="← Назад" 
                    onAction="#goBack"
                    styleClass="button-secondary"/>
            <Label text="Профиль" styleClass="label-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🚪 Выйти из аккаунта" 
                    onAction="#logout"
                    styleClass="button-danger"
                    style="-fx-font-size: 14px;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 30;">
                
                <VBox spacing="25" maxWidth="700" styleClass="card">

                    <!-- Заголовок профиля -->
                    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 0 10 0;">
                        <StackPane style="-fx-background-color: #4a5fd8; -fx-background-radius: 40; -fx-min-width: 64; -fx-min-height: 64; -fx-max-width: 64; -fx-max-height: 64;">
                            <Label fx:id="avatarLabel" 
                                   text="👤" 
                                   style="-fx-font-size: 28px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label fx:id="userNameDisplay" 
                                   text="Имя пользователя"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #222;"/>
                            <Label text="Личный кабинет" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
                        </VBox>
                    </HBox>

                    <Separator styleClass="separator-line"/>

                    <!-- Форма редактирования -->
                    <GridPane hgap="20" vgap="20">
                        
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Логин" styleClass="label-subtitle" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="usernameField" 
                                       promptText="Введите логин"
                                       styleClass="text-field"
                                       style="-fx-font-size: 15px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Полное имя" styleClass="label-subtitle" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="nameField" 
                                       promptText="Введите имя"
                                       styleClass="text-field"
                                       style="-fx-font-size: 15px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Email" styleClass="label-subtitle" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" 
                                       promptText="Введите email"
                                       styleClass="text-field"
                                       style="-fx-font-size: 15px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Телефон" styleClass="label-subtitle" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" 
                                       promptText="Введите телефон"
                                       styleClass="text-field"
                                       style="-fx-font-size: 15px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Новый пароль" styleClass="label-subtitle" style="-fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField" 
                                          promptText="Оставьте пустым, если не меняете"
                                          styleClass="text-field"
                                          style="-fx-font-size: 15px;"/>
                        </VBox>

                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="Текущий пароль *" styleClass="label-subtitle" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                            <PasswordField fx:id="currentPasswordField" 
                                          promptText="Обязательно для сохранения"
                                          styleClass="text-field"
                                          style="-fx-font-size: 15px;"/>
                        </VBox>
                        
                    </GridPane>

                    <!-- Статус -->
                    <Label fx:id="statusLabel" 
                           text="" 
                           wrapText="true"
                           visible="false"
                           alignment="CENTER"
                           maxWidth="Infinity"
                           style="-fx-padding: 12; -fx-background-color: #f0f0f0; -fx-background-radius: 8;"/>

                    <!-- Кнопки -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button text="💾 Сохранить изменения"
                                onAction="#saveProfile"
                                styleClass="button-primary"
                                maxWidth="Infinity"
                                prefWidth="280"
                                style="-fx-font-size: 16px; -fx-padding: 14 28;"
                                HBox.hgrow="ALWAYS"/>
                        <Button text="Отмена"
                                onAction="#goBack"
                                styleClass="button-secondary"
                                prefWidth="130"
                                style="-fx-font-size: 16px;"/>
                    </HBox>

                    <VBox spacing="10" alignment="CENTER" style="-fx-padding: 15 0 0 0;">
                        <Label text="💡 Требования безопасности" 
                               styleClass="label-subtitle"
                               style="-fx-font-weight: bold;"/>
                        <Label text="• Для сохранения любых изменений требуется ввод текущего пароля" 
                               styleClass="label-small"
                               wrapText="true"/>
                        <Label text="• Новый пароль вводите только если хотите его изменить" 
                               styleClass="label-small"
                               wrapText="true"/>
                    </VBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
