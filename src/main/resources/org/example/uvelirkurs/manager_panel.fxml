<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.uvelirkurs.controllers.ManagerPanelController"
      style="-fx-background-color: #f0f2f5;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-padding: 16 24; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <VBox spacing="3">
                <Label text="Панель Менеджера"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Управление товарами и каталогом"
                       style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="10">
                <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24" visible="false"/>
                <Label fx:id="statusLabel" visible="false" style="-fx-font-size: 13px;"/>
            </HBox>
            <Button text="Выйти из аккаунта" onAction="#logout"
                    style="-fx-background-color: #fee2e2; -fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24;">

            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: white; -fx-padding: 16 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                <TextField fx:id="searchField" promptText="Поиск по названию, материалу..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-size: 14px; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;"/>
                <Button text="Найти" onAction="#searchProducts"
                        style="-fx-background-color: #4a5fd8; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Separator orientation="VERTICAL"/>
                <Button text="+ Добавить товар" onAction="#addProduct"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Каталог товаров"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </HBox>

                <Separator/>

                <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="productIdColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="productNameColumn" text="Название" prefWidth="340"/>
                        <TableColumn fx:id="materialColumn" text="Материал" prefWidth="160"/>
                        <TableColumn fx:id="priceColumn" text="Цена (₽)" prefWidth="120"/>
                        <TableColumn fx:id="stockColumn" text="На складе" prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 40;">
                            <Label text="Нет товаров в каталоге"
                                   style="-fx-font-size: 15px; -fx-text-fill: #aaa;"/>
                        </VBox>
                    </placeholder>
                </TableView>

                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: #f0fdf4; -fx-padding: 10 14; -fx-background-radius: 8;">
                    <Label text="ПКМ по товару — просмотр, редактирование, добавление изображений, удаление"
                           style="-fx-font-size: 12px; -fx-text-fill: #15803d;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <stylesheets>
        <String fx:value="@manager-panel-style.css"/>
    </stylesheets>
</BorderPane>
